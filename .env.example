# =============================================================
# .env.example — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The pipeline loads .env automatically via python-dotenv.
# DO NOT commit your real .env to version control.

# ── Database ──────────────────────────────────────────────────
# Override the SQLite path from config.yaml (optional)
# DB_PATH=data/processed/cmdb.sqlite

# ── Kaggle API (for NASA Bearing dataset download) ────────────
# Get your token at: https://www.kaggle.com/settings → API → Create New Token
# Then place kaggle.json at ~/.kaggle/kaggle.json, or set these:
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Power BI (optional — for automated refresh via API) ───────
# POWERBI_CLIENT_ID=
# POWERBI_CLIENT_SECRET=
# POWERBI_TENANT_ID=
# POWERBI_WORKSPACE_ID=
# POWERBI_DATASET_ID=

# ── Email alerts (optional — for critical asset notifications) ─
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# ALERT_RECIPIENTS=maintenance@company.com,reliability@company.com

# ── Pipeline settings ─────────────────────────────────────────
# Override config.yaml values at runtime
# LOG_LEVEL=INFO        # DEBUG, INFO, WARNING, ERROR
# RANDOM_SEED=42
